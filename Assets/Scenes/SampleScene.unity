    \u043D\u0430 \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u044B \u0438\u043D\u0442\u0435\u0440\u0444\u0435\u0439\u0441\u0430
    \u0434\u043B\u044F \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F \u0441\u043F\u0440\u0430\u0432\u043E\u0447\u043D\u043E\u0439
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438.\n2. \u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439\u0442\u0435
    \u043A\u043D\u043E\u043F\u043A\u0438 \u043F\u0430\u043D\u0435\u043B\u0438 \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0434\u043B\u044F \u0432\u044B\u0431\u043E\u0440\u0430 \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u043E\u0432
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0438.\n3. \u041D\u0430\u0436\u0438\u043C\u0430\u0439\u0442\u0435
    \u043D\u0430 \u043A\u043D\u043E\u043F\u043A\u0438 \u0434\u043B\u044F \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0430
    \u043A\u0430\u043C\u0435\u0440\u044B \u043A \u043D\u0443\u0436\u043D\u043E\u043C\u0443
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0443.\n4. \u0414\u043B\u044F \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0430
    \u043A \u0442\u0440\u0435\u043D\u0438\u0440\u043E\u0432\u043A\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439\u0442\u0435
    \u043A\u043D\u043E\u043F\u043A\u0443 \xAB\u041F\u0420\u0410\u041A\u0422\u0418\u041A\u0410\xBB."
